@startuml classification_class

' Design adjustments for high readability
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam class {
    BackgroundColor White
    BorderColor #333333
    ArrowColor #666666
}
skinparam note {
    BackgroundColor #F6F8FA
    BorderColor #D1D5DB
}

package src.utils {
    class helpers <<module>> {
        + load_config(path: Path) : dict
        + load_dataset(path: Path) : DataFrame
    }
}

package src.analysis {
    class classification <<module>> {
        .. Configuration ..
        - OUTPUT_DIR : Path = "output/classification"
        - FEATURES : list[str] = ["average_grade", "attendance"]
        - TARGET : str = "major"
        - RANDOM_STATE : int = 42
        
        __ Data Preparation __
        + prepare_data(df: DataFrame, test_size: float) : tuple
        
        __ Model Training & Evaluation __
        + evaluate_model(model, X_test: ndarray, y_test: ndarray, name: str) : dict
        
        __ Plotting & Visualizations __
        + plot_confusion_matrix(model, X_test: ndarray, y_test: ndarray, name: str, path: Path) : void
        + plot_decision_boundary(model, scaler, X_train, y_train, X_test, y_test, name: str, path: Path) : void
        
        __ Error & Risk Analysis __
        + analyze_errors(model, X_test: ndarray, y_test: ndarray, scaler: StandardScaler) : dict
        
        __ Execution & Report __
        + run(cfg: dict) : dict
        - _build_synthesis(metrics: dict, err: dict) : str
        + print_report(summary: dict) : void
    }
}

note bottom of classification
  <b>Question 4 — Major Prediction (Supervised ML)</b>
  • Splits data (70% train / 30% test) and standardizes features.
  • Trains and compares Logistic Regression & Decision Tree models.
  • Performs detailed error analysis (False Positives / False Negatives).
  • Assesses the pedagogical risks of misclassification.
end note

classification ..> helpers : uses
classification ..> "output/classification/" : writes JSON & PNG

@enduml
